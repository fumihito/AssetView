#!/usr/bin/env bash
# build — Windows 向けクロスコンパイルビルドスクリプト
# Usage:
#   ./build                    → リリースビルド
#   ./build debug              → デバッグビルド
#   ./build --rebuild          → キャッシュを削除してからリリースビルド
#   ./build debug --rebuild    → キャッシュを削除してからデバッグビルド
set -euo pipefail

TARGET="x86_64-pc-windows-gnu"
PROFILE="release"
REBUILD=0

for arg in "$@"; do
    case "${arg}" in
        --rebuild) REBUILD=1 ;;
        debug)     PROFILE="debug" ;;
        release)   PROFILE="release" ;;
        *) echo "Unknown argument: ${arg}" >&2; exit 1 ;;
    esac
done

if [[ "${PROFILE}" == "debug" ]]; then
    CARGO_FLAGS=()
    OUT="target/${TARGET}/debug/AssetView.exe"
else
    CARGO_FLAGS=(--release)
    OUT="target/${TARGET}/release/AssetView.exe"
fi

step() { echo ""; echo "==> $*"; }

# ── 1. rustup ────────────────────────────────────────────────────────────────
# システム Rust (apt 版) にはターゲット管理機能がないため、
# rustup が無ければユーザーホームに追加インストールする。
[[ -f "${HOME}/.cargo/env" ]] && source "${HOME}/.cargo/env"

if ! command -v rustup &>/dev/null; then
    step "rustup をインストール中..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path
    source "${HOME}/.cargo/env"
fi

# ── 2. mingw-w64 クロスリンカー ───────────────────────────────────────────────
if ! command -v x86_64-w64-mingw32-gcc &>/dev/null; then
    step "gcc-mingw-w64-x86-64 をインストール中..."
    sudo apt-get install -y gcc-mingw-w64-x86-64
fi

# ── 3. Windows 向け Rust 標準ライブラリ ──────────────────────────────────────
if ! rustup target list --installed | grep -q "^${TARGET}"; then
    step "Rust ターゲット ${TARGET} を追加中..."
    rustup target add "${TARGET}"
fi

# ── 4. ビルド ─────────────────────────────────────────────────────────────────
if [[ "${REBUILD}" == "1" ]]; then
    step "AssetView のビルドキャッシュを削除 (依存クレートは維持)"
    # fingerprint を消すことで cargo が自パッケージだけを再コンパイルする
    local_dir="target/${TARGET}/${PROFILE}"
    rm -f  "${local_dir}/AssetView.exe" "${local_dir}/AssetView.d"
    rm -f  "${local_dir}/deps/AssetView"-*.{d,exe,o} 2>/dev/null || true
    rm -rf "${local_dir}/.fingerprint/AssetView"-*
fi

step "cargo build ${CARGO_FLAGS[*]:-} --target ${TARGET}"
cargo build "${CARGO_FLAGS[@]}" --target "${TARGET}"

echo ""
echo "✓ ${OUT}"
