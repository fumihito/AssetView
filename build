#!/usr/bin/env bash
# build - Windows cross-compilation build script
# Usage:
#   ./build                    -> release build
#   ./build debug              -> debug build
#   ./build --rebuild          -> release build after clearing the local cache
#   ./build debug --rebuild    -> debug build after clearing the local cache
set -euo pipefail

TARGET="x86_64-pc-windows-gnu"
PROFILE="release"
REBUILD=0

for arg in "$@"; do
    case "${arg}" in
        --rebuild) REBUILD=1 ;;
        debug)     PROFILE="debug" ;;
        release)   PROFILE="release" ;;
        *) echo "Unknown argument: ${arg}" >&2; exit 1 ;;
    esac
done

if [[ "${PROFILE}" == "debug" ]]; then
    CARGO_FLAGS=()
    OUT="target/${TARGET}/debug/AssetView.exe"
else
    CARGO_FLAGS=(--release)
    OUT="target/${TARGET}/release/AssetView.exe"
fi

step() { echo ""; echo "==> $*"; }

# ── 1. rustup ────────────────────────────────────────────────────────────────
# The system Rust package does not provide target management, so install
# rustup into the user home directory if it is missing.
[[ -f "${HOME}/.cargo/env" ]] && source "${HOME}/.cargo/env"

if ! command -v rustup &>/dev/null; then
    step "Installing rustup..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path
    source "${HOME}/.cargo/env"
fi

# ── 2. mingw-w64 cross linker ────────────────────────────────────────────────
if ! command -v x86_64-w64-mingw32-gcc &>/dev/null; then
    step "Installing gcc-mingw-w64-x86-64..."
    sudo apt-get install -y gcc-mingw-w64-x86-64
fi

# ── 3. Windows Rust standard library ────────────────────────────────────────
if ! rustup target list --installed | grep -q "^${TARGET}"; then
    step "Adding Rust target ${TARGET}..."
    rustup target add "${TARGET}"
fi

# ── 4. Build ──────────────────────────────────────────────────────────────────
if [[ "${REBUILD}" == "1" ]]; then
    step "Clearing the AssetView build cache (keeping dependency crates)"
    # Removing fingerprints tells cargo to rebuild only this package.
    local_dir="target/${TARGET}/${PROFILE}"
    rm -f  "${local_dir}/AssetView.exe" "${local_dir}/AssetView.d"
    rm -f  "${local_dir}/deps/AssetView"-*.{d,exe,o} 2>/dev/null || true
    rm -rf "${local_dir}/.fingerprint/AssetView"-*
fi

step "cargo build ${CARGO_FLAGS[*]:-} --target ${TARGET}"
cargo build "${CARGO_FLAGS[@]}" --target "${TARGET}"

echo ""
echo "✓ ${OUT}"
